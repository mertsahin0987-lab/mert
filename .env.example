# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — never commit your real keys.

# Supabase project URL (same as in lib/supabase.ts)
SUPABASE_URL=https://xgoiabfbetftjomtvcgb.supabase.co

# SERVICE ROLE key — gives full DB write access. Server-side only.
# Find it: Supabase Dashboard → Project Settings → API → "service_role" / "secret" key
# NEVER paste this in app code or share it — it bypasses Row-Level Security.
SUPABASE_SERVICE_ROLE_KEY=paste-your-secret-key-here
